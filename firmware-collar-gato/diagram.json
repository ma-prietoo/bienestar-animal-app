  "connections": [
    [ "esp:TX0", "$serialMonitor:RX", "", [] ],
    [ "esp:RX0", "$serialMonitor:TX", "", [] ],
    [ "esp:3V3", "imu:VCC", "red", [] ],
    [ "esp:GND.1", "imu:GND", "black", [] ],
    [ "esp:D21", "imu:SDA", "green", [] ],
    [ "esp:D22", "imu:SCL", "yellow", [] ],
    [ "esp:3V3", "temp_sensor:VCC", "red", [] ],
    [ "esp:GND.1", "temp_sensor:GND", "black", [] ],
    [ "esp:D34", "temp_sensor:OUT", "purple", [] ],
    [ "esp:3V3", "bat_pot:VCC", "red", [] ],
    [ "esp:GND.1", "bat_pot:GND", "black", [] ],
    [ "esp:D35", "bat_pot:SIG", "brown", [] ],
