    { "type": "wokwi-ntc-temperature-sensor", "id": "temp_sensor", "top": 70, "left": -210, "attrs": { "temperature": "38.3", "label": "Temp" } },
    { "type": "wokwi-potentiometer", "id": "bat_pot", "top": 210, "left": -210, "attrs": { "label": "Bateria" } },
    { "type": "wokwi-led", "id": "led_gnss", "top": -95, "left": 270, "attrs": { "color": "blue", "label": "GNSS" } },
    { "type": "wokwi-led", "id": "led_ble", "top": -35, "left": 270, "attrs": { "color": "green", "label": "BLE" } },
    { "type": "wokwi-led", "id": "led_activity", "top": 25, "left": 270, "attrs": { "color": "orange", "label": "Actividad" } },
    { "type": "wokwi-pushbutton", "id": "btn_imu", "top": 100, "left": 260, "attrs": { "label": "IMU Wake" } },
    { "type": "wokwi-pushbutton", "id": "btn_ble_loss", "top": 170, "left": 260, "attrs": { "label": "BLE perdido" } },
    { "type": "wokwi-pushbutton", "id": "btn_temp", "top": 240, "left": 260, "attrs": { "label": "Temp alta" } },
    { "type": "wokwi-pushbutton", "id": "btn_inactivity", "top": 310, "left": 260, "attrs": { "label": "Inactividad" } },
