    [ "led_activity:C", "esp:GND.2", "black", [] ],
    [ "btn_imu:1.l", "esp:D13", "orange", [] ],
    [ "btn_imu:2.r", "esp:GND.2", "black", [] ],
    [ "btn_ble_loss:1.l", "esp:D12", "orange", [] ],
    [ "btn_ble_loss:2.r", "esp:GND.2", "black", [] ],
    [ "btn_temp:1.l", "esp:D14", "orange", [] ],
    [ "btn_temp:2.r", "esp:GND.2", "black", [] ],
    [ "btn_inactivity:1.l", "esp:D27", "orange", [] ],
    [ "btn_inactivity:2.r", "esp:GND.2", "black", [] ],
    [ "btn_low_battery:1.l", "esp:D26", "orange", [] ],
    [ "btn_low_battery:2.r", "esp:GND.2", "black", [] ]
